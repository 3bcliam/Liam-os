<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Liam OS">
<title>Liam OS</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#080808;--surface:#111;--card:#161616;--border:#1e1e1e;--dim:#1a1a1a;--dim2:#2a2a2a;
  --text:#f0ece4;--muted:#484848;--gold:#d4b84a;--green:#3db87a;--red:#e05c4b;--blue:#4a8fe8;
  --business:#d4b84a;--fitness:#3db87a;--relationships:#e05c4b;
  --chest:#e05c4b;--back:#4a8fe8;--legs:#d4b84a;--shoulders:#8e5ce8;--arms:#3db87a;--core:#d4733a;
}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;padding-bottom:72px;padding-top:env(safe-area-inset-top)}
input[type=number]::-webkit-inner-spin-button,input[type=number]::-webkit-outer-spin-button{-webkit-appearance:none}
input[type=range]{-webkit-appearance:none;width:100%;height:20px;background:transparent;cursor:pointer;position:absolute;top:-7px;left:0;opacity:0;z-index:2}
.bebas{font-family:'Bebas Neue',sans-serif}
/* NAV */
#nav{position:fixed;bottom:0;left:0;right:0;background:var(--surface);border-top:1px solid var(--border);display:flex;z-index:99;padding-bottom:env(safe-area-inset-bottom)}
.nav-btn{flex:1;padding:10px 0 8px;background:none;border:none;cursor:pointer;color:var(--muted);font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;display:flex;flex-direction:column;align-items:center;gap:2px;border-top:2px solid transparent;transition:all 0.2s}
.nav-btn.active{color:var(--text);border-top-color:var(--gold)}
.nav-icon{font-size:18px}
/* TOAST */
#toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(60px);background:var(--text);color:var(--bg);padding:10px 20px;border-radius:8px;font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:1px;transition:transform 0.3s;z-index:200;white-space:nowrap;pointer-events:none}
#toast.show{transform:translateX(-50%) translateY(0)}
/* PANELS */
.panel{display:none}.panel.active{display:block}
/* CARDS */
.card{background:var(--card);border:1px solid var(--border);border-radius:10px}
/* BUTTONS */
.btn-primary{width:100%;padding:14px;border:none;border-radius:8px;font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:3px;cursor:pointer;transition:opacity 0.2s}
.btn-primary:hover{opacity:0.85}
.btn-ghost{background:none;border:1px solid var(--border);border-radius:7px;color:var(--muted);font-family:'Bebas Neue',sans-serif;font-size:11px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;padding:9px 22px}

/* ── MORNING ── */
#morning-launch{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;cursor:pointer;position:relative;overflow:hidden;background:#080808}
.grid-bg{position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,0.018) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,0.018) 1px,transparent 1px);background-size:44px 44px}
#launch-time{font-family:‘Bebas Neue’,sans-serif;font-size:80px;letter-spacing:4px;color:var(–text);line-height:1;position:relative;z-index:1}
#launch-date{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(–muted);margin-top:6px;position:relative;z-index:1}
.gold-line{width:48px;height:1px;background:var(–gold);margin:28px 0;position:relative;z-index:1}
#launch-quote{font-weight:600;font-size:18px;color:var(–text);text-align:center;line-height:1.65;letter-spacing:0.2px;max-width:320px;position:relative;z-index:1}
#launch-streak{margin-top:36px;display:flex;align-items:center;gap:12px;position:relative;z-index:1}
.streak-num{font-family:‘Bebas Neue’,sans-serif;font-size:52px;color:var(–gold);line-height:1}
.streak-lbl{font-size:11px;color:var(–muted);letter-spacing:2px;text-transform:uppercase;line-height:1.6}
.tap-hint{position:absolute;bottom:40px;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(–muted);z-index:1}

#morning-done{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;background:#080808}

#morning-checklist{padding-bottom:20px}
.m-header{padding:24px 22px 0}
.progress-row{display:flex;justify-content:space-between;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(–muted);margin-bottom:7px}
.progress-bar{height:3px;background:var(–border);border-radius:2px;margin:0 22px}
.progress-fill{height:100%;border-radius:2px;transition:width 0.35s}
.quote-strip{margin:14px 22px 0;padding:13px 15px;background:var(–dim);border-radius:9px;border-left:3px solid var(–gold);font-size:13px;line-height:1.65;font-weight:500}
.task-list{padding:14px 22px 0}
.task-item{display:flex;align-items:center;gap:14px;padding:15px 0;border-bottom:1px solid var(–border);cursor:pointer;transition:opacity 0.2s}
.task-item:last-child{border-bottom:none}
.task-item.done{opacity:0.45}
.task-check{width:26px;height:26px;border-radius:50%;border:2px solid var(–border);background:none;display:flex;align-items:center;justify-content:center;color:var(–green);font-size:13px;flex-shrink:0;transition:all 0.2s}
.task-check.done{border-color:var(–green);background:rgba(61,184,122,0.15)}
.task-icon{font-size:20px}
.task-label{font-weight:500;font-size:16px}
.task-item.done .task-label{text-decoration:line-through;color:var(–muted)}
.streak-card{margin:20px 22px 0;padding:18px;background:var(–dim);border-radius:12px;display:flex;justify-content:space-between;align-items:center}
.week-dots{display:flex;gap:5px;margin-top:8px}
.week-dot{width:12px;height:12px;border-radius:3px;background:var(–border)}
.week-dot.done{background:var(–green)}

/* ── LIFT ── */
.day-strip{display:flex;gap:7px;padding:14px 22px 0;overflow-x:auto;scrollbar-width:none}
.day-strip::-webkit-scrollbar{display:none}
.day-btn{flex-shrink:0;padding:8px 13px;border-radius:6px;border:1px solid var(–border);background:var(–surface);color:var(–muted);font-family:‘Bebas Neue’,sans-serif;font-size:13px;letter-spacing:1px;cursor:pointer;white-space:nowrap;transition:all 0.2s}
.ex-card{background:var(–card);border:1px solid var(–border);border-radius:10px;margin-bottom:10px;overflow:hidden}
.ex-header{display:flex;align-items:center;padding:12px 14px;gap:10px;cursor:pointer}
.ex-num{width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:‘Bebas Neue’,sans-serif;font-size:11px;color:var(–bg);flex-shrink:0}
.ex-name{font-weight:600;font-size:14px}
.ex-target{font-size:11px;color:var(–muted);margin-top:1px}
.swap-btn{padding:5px 9px;background:var(–surface);border:1px solid var(–border);border-radius:5px;color:var(–muted);font-size:10px;letter-spacing:1px;text-transform:uppercase;cursor:pointer}
.chevron{color:var(–muted);margin-left:6px;display:inline-block;transition:transform 0.2s;font-size:14px}
.ex-card.open .chevron{transform:rotate(180deg)}
.sets-container{display:none;padding:0 14px 14px}
.ex-card.open .sets-container{display:block}
.prog-bar-strip{background:var(–surface);border-radius:6px;padding:8px 12px;margin-bottom:10px;display:flex;justify-content:space-between;font-size:12px}
.sets-header{display:grid;grid-template-columns:24px 1fr 1fr 50px 32px;gap:6px;padding:0 0 6px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(–muted)}
.set-row{display:grid;grid-template-columns:24px 1fr 1fr 50px 32px;gap:6px;align-items:center;margin-bottom:6px}
.set-num-lbl{font-family:‘Bebas Neue’,sans-serif;font-size:14px;color:var(–muted);text-align:center}
.set-input{background:var(–surface);border:1px solid var(–dim2);border-radius:6px;color:var(–text);font-family:‘Bebas Neue’,sans-serif;font-size:15px;font-weight:700;padding:9px 6px;text-align:center;width:100%}
.set-input:focus{outline:none;border-color:var(–muted)}
.set-input.done{background:#0d0d0d;border-color:var(–border)}
.done-btn{width:32px;height:32px;border-radius:50%;border:2px solid var(–border);background:none;color:var(–muted);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s}
.done-btn.done{border-color:var(–green);background:rgba(61,184,122,0.12);color:var(–green)}
.add-set-btn{width:100%;padding:8px;background:none;border:1px dashed var(–border);border-radius:6px;color:var(–muted);font-size:11px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;margin-top:2px}
.summary-card{margin:12px 22px 0;background:var(–card);border:1px solid var(–border);border-radius:10px;padding:16px}
.summary-row{display:flex;justify-content:space-between;font-size:13px;padding:6px 0;border-bottom:1px solid var(–border)}
.summary-row:last-child{border-bottom:none}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:100;align-items:flex-end}
.modal-overlay.open{display:flex}
.modal-box{background:var(–card);border:1px solid var(–border);border-radius:14px 14px 0 0;width:100%;max-height:78vh;display:flex;flex-direction:column}
.modal-head{padding:18px 18px 12px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(–border)}
.modal-close{width:30px;height:30px;border-radius:50%;border:1px solid var(–border);background:none;color:var(–text);cursor:pointer;font-size:16px}
.modal-search{margin:10px 18px;padding:10px 14px;background:var(–surface);border:1px solid var(–border);border-radius:8px;color:var(–text);font-size:14px;width:calc(100% - 36px)}
.modal-search:focus{outline:none}
.modal-list{overflow-y:auto;padding:0 18px 18px;-webkit-overflow-scrolling:touch}
.ex-option{padding:13px 0;border-bottom:1px solid var(–border);cursor:pointer;display:flex;justify-content:space-between;align-items:center}
.ex-option:last-child{border-bottom:none}
.ex-option:active{opacity:0.6}
.ex-option-name{font-weight:600;font-size:14px}
.ex-option-sub{font-size:11px;color:var(–muted);margin-top:2px}
.ex-tag{font-size:10px;padding:3px 7px;border-radius:4px;background:var(–surface);color:var(–muted);letter-spacing:1px;text-transform:uppercase;flex-shrink:0}

/* ── PYRAMID ── */
.subtabs{display:flex;gap:4px;margin:14px 22px 0;background:var(–surface);border-radius:8px;padding:4px;border:1px solid var(–border)}
.subtab{flex:1;padding:9px 0;background:none;border:none;border-radius:5px;color:var(–muted);font-family:‘Bebas Neue’,sans-serif;font-size:13px;letter-spacing:2px;cursor:pointer;text-transform:uppercase;transition:all 0.2s}
.subtab.active{background:var(–border);color:var(–text)}
.subpanel{display:none}.subpanel.active{display:block}
.pillar-slider{margin-bottom:20px}
.pillar-top{display:flex;justify-content:space-between;margin-bottom:8px}
.pillar-name{font-family:‘Bebas Neue’,sans-serif;font-size:18px;letter-spacing:1px;text-transform:uppercase}
.pillar-val{font-family:‘Bebas Neue’,sans-serif;font-size:24px}
.slider-wrap{position:relative;height:6px;background:var(–border);border-radius:3px}
.slider-fill{position:absolute;top:0;left:0;height:100%;border-radius:3px;transition:width 0.1s;pointer-events:none}
.p-notes{width:100%;background:var(–bg);border:1px solid var(–border);border-radius:6px;color:var(–text);font-size:14px;padding:12px;resize:none;font-family:inherit;margin-bottom:12px}
.p-notes:focus{outline:none;border-color:var(–muted)}
.type-btns{display:flex;gap:8px;margin-bottom:8px}
.type-btn{flex:1;padding:11px;background:var(–surface);border:1px solid var(–border);border-radius:6px;color:var(–muted);font-family:‘Bebas Neue’,sans-serif;font-size:14px;letter-spacing:2px;cursor:pointer;text-transform:uppercase;transition:all 0.2s}
.type-btn.active{border-color:var(–text);color:var(–text)}
.diag-grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:12px}
.diag-mini{background:var(–card);border:1px solid var(–border);border-radius:10px;padding:14px 8px;text-align:center}
.diag-mini-val{font-family:‘Bebas Neue’,sans-serif;font-size:30px;line-height:1}
.diag-mini-lbl{font-size:10px;color:var(–muted);letter-spacing:1px;text-transform:uppercase;margin-top:3px}
.history-item{padding:14px 16px;border-bottom:1px solid var(–border)}
.history-item:last-child{border-bottom:none}
.hist-top{display:flex;justify-content:space-between;margin-bottom:8px}
.hist-badge{font-size:10px;padding:2px 7px;border-radius:3px;letter-spacing:1px;text-transform:uppercase}
.hist-badge.daily{background:#1a1a2e;color:#6e8efb}
.hist-badge.weekly{background:#1a2e1a;color:var(–green)}
.hist-bars{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px}
.hist-bar-wrap{margin-top:3px}
.hist-bar-top{display:flex;justify-content:space-between;font-size:11px;color:var(–muted);margin-bottom:3px}
.mini-bar{height:3px;background:var(–border);border-radius:2px}
.mini-bar-fill{height:100%;border-radius:2px}
canvas{display:block}
.diag-section{background:var(–card);border:1px solid var(–border);border-radius:10px;padding:16px;margin-bottom:12px;display:flex;flex-direction:column;align-items:center}
.diag-title{font-family:‘Bebas Neue’,sans-serif;font-size:13px;letter-spacing:3px;color:var(–muted);align-self:flex-start;margin-bottom:10px}
.legend{display:flex;gap:16px;justify-content:center;margin-bottom:16px}
.legend-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(–muted)}
.legend-dot{width:8px;height:8px;border-radius:50%}
</style>

</head>
<body>

<!-- ── MORNING PANEL ── -->

<div id="panel-morning" class="panel active">

  <!-- Launch Screen -->

  <div id="morning-launch" onclick="launchTap()">
    <div class="grid-bg"></div>
    <div id="launch-time" class="bebas">4:00 AM</div>
    <div id="launch-date"></div>
    <div class="gold-line"></div>
    <div id="launch-quote">"There is someone out there that is currently out working you. One step ahead of you. Change that."</div>
    <div id="launch-streak" style="display:none">
      <div class="streak-num bebas" id="launch-streak-num">0</div>
      <div class="streak-lbl">Day<br>Streak</div>
      <div style="font-size:28px;margin-left:4px">🔥</div>
    </div>
    <div class="tap-hint">Tap to lock in</div>
  </div>

  <!-- Done Screen -->

  <div id="morning-done" style="display:none">
    <div style="font-size:72px;margin-bottom:16px">💪</div>
    <div class="bebas" style="font-size:56px;letter-spacing:4px;color:var(--green);line-height:1;text-align:center">Session<br>Complete</div>
    <div class="bebas" style="font-size:22px;color:var(--gold);margin-top:16px;letter-spacing:2px" id="done-streak">0 Day Streak 🔥</div>
    <div style="font-size:14px;color:var(--muted);margin-top:12px;text-align:center;line-height:1.7;max-width:260px">One step ahead of everyone who stayed in bed.</div>
    <button class="btn-ghost" style="margin-top:40px" onclick="showChecklist()">View Checklist</button>
  </div>

  <!-- Checklist -->

  <div id="morning-checklist" style="display:none">
    <div class="m-header">
      <div class="bebas" style="font-size:11px;letter-spacing:4px;color:var(--muted);text-transform:uppercase" id="cl-date"></div>
      <div class="bebas" style="font-size:36px;letter-spacing:2px;line-height:1.1;margin-top:4px">Morning<br>Lock In</div>
    </div>
    <div style="margin:18px 22px 0">
      <div class="progress-row">
        <span>Progress</span>
        <span id="prog-count">0/6</span>
      </div>
      <div class="progress-bar">
        <div class="progress-fill" id="prog-fill" style="width:0%;background:var(--gold)"></div>
      </div>
    </div>
    <div class="quote-strip">"There is someone out there that is currently out working you. One step ahead of you. Change that."</div>
    <div class="task-list" id="task-list"></div>
    <div class="streak-card">
      <div>
        <div class="bebas" style="font-size:11px;letter-spacing:3px;color:var(--muted);text-transform:uppercase">Streak</div>
        <div style="display:flex;align-items:baseline;gap:8px;margin-top:4px">
          <div class="bebas" style="font-size:48px;color:var(--gold);line-height:1" id="streak-display">0</div>
          <div class="bebas" style="font-size:16px;color:var(--muted)">Days 🔥</div>
        </div>
      </div>
      <div>
        <div class="bebas" style="font-size:11px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;text-align:right">This Week</div>
        <div class="week-dots" id="week-dots"></div>
      </div>
    </div>
    <div style="margin:16px 22px 0;text-align:center">
      <button class="btn-ghost" onclick="showLaunch()">Back to Launch</button>
    </div>
  </div>
</div>

<!-- ── LIFT PANEL ── -->

<div id="panel-lift" class="panel">
  <div style="display:flex;justify-content:space-between;align-items:center;padding:22px 22px 0">
    <div class="bebas" id="lift-logo" style="font-size:42px;letter-spacing:2px">LIFT</div>
    <div style="text-align:right">
      <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)">Today</div>
      <div class="bebas" style="font-size:18px" id="lift-date"></div>
    </div>
  </div>
  <div class="day-strip" id="day-strip"></div>
  <div style="margin:14px 22px 0;padding:15px;border-radius:10px;border:1px solid var(--border);background:var(--card);display:flex;justify-content:space-between;align-items:center">
    <div>
      <div class="bebas" style="font-size:26px" id="session-muscle">Chest</div>
      <div style="font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-top:2px" id="session-num">Session 1</div>
    </div>
    <div style="font-size:11px;color:var(--muted);text-align:right;max-width:130px;line-height:1.5">
      <span style="color:var(--text);font-weight:600;display:block">Double Progression</span>Hit top rep → weight up
    </div>
  </div>
  <div style="padding:12px 22px 0" id="exercises-list"></div>
  <div style="margin:12px 22px 0">
    <button class="btn-primary" id="complete-btn" onclick="completeSession()">Complete Session</button>
  </div>
  <div id="lift-summary" style="display:none" class="summary-card"></div>
</div>

<!-- ── PYRAMID PANEL ── -->

<div id="panel-pyramid" class="panel">
  <div style="padding:22px 22px 0;display:flex;justify-content:space-between;align-items:center">
    <div>
      <div class="bebas" style="font-size:36px;letter-spacing:3px;line-height:1">The Pyramid</div>
      <div style="font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:3px">Business · Fitness · Relationships</div>
    </div>
    <div style="text-align:right" id="pyramid-overall-header"></div>
  </div>
  <div class="subtabs">
    <button class="subtab active" onclick="setSubtab('log',this)">Log</button>
    <button class="subtab" onclick="setSubtab('diagram',this)">Diagram</button>
    <button class="subtab" onclick="setSubtab('history',this)">History</button>
  </div>

  <!-- Log -->

  <div id="subpanel-log" class="subpanel active" style="padding:14px 22px 0">
    <div class="card" style="padding:18px">
      <div class="pillar-slider" id="slider-business">
        <div class="pillar-top">
          <span class="pillar-name" style="color:var(--business)">Business</span>
          <span class="pillar-val" style="color:var(--business)" id="val-business">50%</span>
        </div>
        <div class="slider-wrap">
          <div class="slider-fill" id="fill-business" style="width:50%;background:var(--business)"></div>
          <input type="range" min="0" max="100" value="50" oninput="updateSlider('business',this.value)">
        </div>
      </div>
      <div class="pillar-slider" id="slider-fitness">
        <div class="pillar-top">
          <span class="pillar-name" style="color:var(--fitness)">Fitness</span>
          <span class="pillar-val" style="color:var(--fitness)" id="val-fitness">50%</span>
        </div>
        <div class="slider-wrap">
          <div class="slider-fill" id="fill-fitness" style="width:50%;background:var(--fitness)"></div>
          <input type="range" min="0" max="100" value="50" oninput="updateSlider('fitness',this.value)">
        </div>
      </div>
      <div class="pillar-slider" id="slider-relationships">
        <div class="pillar-top">
          <span class="pillar-name" style="color:var(--relationships)">Relationships</span>
          <span class="pillar-val" style="color:var(--relationships)" id="val-relationships">50%</span>
        </div>
        <div class="slider-wrap">
          <div class="slider-fill" id="fill-relationships" style="width:50%;background:var(--relationships)"></div>
          <input type="range" min="0" max="100" value="50" oninput="updateSlider('relationships',this.value)">
        </div>
      </div>
      <textarea class="p-notes" id="p-notes" rows="3" placeholder="Notes (optional)..."></textarea>
      <div class="type-btns">
